{
  "buildCommand": "pnpm vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.{ts,js}": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}